# =============================================================================
# Trend Business AI — STAGING environment template (Phase 12)
# Copy to .env.staging (gitignored) or Vercel Preview env.
# Guide: docs/STAGING_SETUP.md
# Verify: npm run verify:staging [-- --strict]
# Live HTTP: STAGING_BASE_URL=https://your-staging-host
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://staging.your-domain
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Optional: direct Postgres for npm run db:apply against staging
# SUPABASE_DB_URL=

DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENAI_API_KEY=

# PayPal sandbox only on staging
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
# BILLING_OPTIONAL=false
# ALLOW_INSECURE_PAYPAL_WEBHOOKS=false

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

LOG_LEVEL=info
# HEALTH_DETAILED=true

WEBSITE_PREVIEW_BUILDER_ENABLED=false
# WEBSITE_PUBLISH_ENABLED=true

# Used by npm run verify:staging / smoke:staging (optional locally)
# STAGING_BASE_URL=https://staging.your-domain
