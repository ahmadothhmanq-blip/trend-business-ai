# =============================================================================
# Trend Business AI — environment
# Platform launch: docs/PRODUCTION_LAUNCH.md + docs/LAUNCH_CHECKLIST.md
# Staging: docs/STAGING_SETUP.md + .env.staging.example
# Website Builder detail: docs/WEBSITE_BUILDER_DEPLOYMENT_READY.md
# Production P0: SITE_URL (https), Supabase URL+anon, SERVICE_ROLE, DEEPSEEK_API_KEY
# Verify: npm run verify:launch [-- --production]
# Staging verify: npm run verify:staging [-- --strict]
# Go-live: npm run verify:golive [-- --production] [-- --paid]
# Optional HTTP: PRODUCTION_BASE_URL=https://your-domain
# Optional error monitoring: SENTRY_DSN=
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local: http://localhost:3000 | Production: https://your-domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database migrations. Direct/session Postgres URI — required for npm run db:apply
# Supabase Dashboard → Project Settings → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# AI — DeepSeek is the default text/code provider (Website Builder + all Core products).
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional text providers (multi-AI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
LLAMA_API_KEY=

# AI Real Images Engine (visual generation only — not used for text/code)
# Preferred: openai | replicate | stability (falls through configured providers)
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY also powers DALL·E when set
# REPLICATE_API_TOKEN=
# REPLICATE_FLUX_MODEL=black-forest-labs/flux-schnell
# STABILITY_API_KEY=
# STABILITY_IMAGE_MODEL=sd3.5-large

# Billing (PayPal Checkout + Visa/Mastercard hosted card flow)
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
# P0 for production: Dashboard → Settings → API → service_role (server-only, never NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=
# Production fail-closed for billing. Set true only for local/demo without billing tables.
# BILLING_OPTIONAL=false
# Dev-only: allow unsigned PayPal webhooks (never in production)
# ALLOW_INSECURE_PAYPAL_WEBHOOKS=false

# Optional logging / health
LOG_LEVEL=info
# HEALTH_DETAILED=false

# SEO / Analytics (optional — enables GSC, GA4, Bing, GTM when set)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# P1 for public launch: global AI/auth rate limiting
# When unset in production, API routes use per-instance memory limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Preview builder (npm install + build on generated projects). RCE risk if enabled.
# H08 / D-004: keep false. Unset or false = off. Production hard-disables even if true.
# Only consider true in local/dev after an Accepted security decision (F01).
WEBSITE_PREVIEW_BUILDER_ENABLED=false

# -----------------------------------------------------------------------------
# Video Studio — AI video production (providers, TTS, FFmpeg, cron worker)
# At least one video provider + TTS + FFmpeg required for full production output.
# Verify: npm run verify:video-studio
# Health: GET /api/video-studio/health (authenticated)
# Cron worker: GET /api/video-studio/cron with Bearer VIDEO_STUDIO_CRON_SECRET
# -----------------------------------------------------------------------------
# Video generation (configure one or more)
# KLING_API_KEY=
# RUNWAY_API_KEY=
# HEYGEN_API_KEY=
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=
# VIDEO_PROVIDER_API_KEY=
# VIDEO_PROVIDER_BASE_URL=
# Voice / TTS
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# OPENAI_API_KEY=
# Assembly (required for multi-scene merge, burn-in, social re-encode)
# FFMPEG_PATH=
# FFPROBE_PATH=
# Production hardening
# VIDEO_PROVIDER_STRICT=1
# VIDEO_STUDIO_CRON_SECRET=
# Apply DB: npm run db:apply -- --only 044,045

# Public hosted websites at /w/[slug]. Default ON when unset. Set false to disable public hosting.
# In-platform live preview uses /api/website-builder/[id]/live-preview (always available when authenticated).
# WEBSITE_PUBLISH_ENABLED=true
# WEBSITE_PUBLISH_ENABLED=false

# App Builder — live preview at /api/webapp-builder/[id]/live-preview (authenticated).
# Deploy URLs use VERCEL_URL or NEXT_PUBLIC_APP_URL when set.
# WEBAPP_DEPLOY_ENABLED=true
# Apply DB: npm run db:apply -- --only 046
