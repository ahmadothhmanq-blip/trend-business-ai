# =============================================================================
# Website Builder / app — see docs/WEBSITE_BUILDER_DEPLOYMENT_READY.md
# Production P0: SITE_URL (https), Supabase URL+anon, SERVICE_ROLE, DEEPSEEK_API_KEY
# Verify: npm run verify:wb-launch -- --production
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local: http://localhost:3000 | Production: https://your-domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database migrations. Direct/session Postgres URI — required for npm run db:apply
# Supabase Dashboard → Project Settings → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# AI — DeepSeek is the default Website Builder provider (P0 for WB launch).
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional additional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
LLAMA_API_KEY=

# Billing (PayPal Checkout + Visa/Mastercard hosted card flow)
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
# P0 for production: Dashboard → Settings → API → service_role (server-only, never NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=
# Production fail-closed for billing. Set true only for local/demo without billing tables.
# BILLING_OPTIONAL=false
# Dev-only: allow unsigned PayPal webhooks (never in production)
# ALLOW_INSECURE_PAYPAL_WEBHOOKS=false

# Optional logging / health
LOG_LEVEL=info
# HEALTH_DETAILED=false

# SEO / Analytics (optional — enables GSC, GA4, Bing, GTM when set)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# P1 for public launch: global AI/auth rate limiting
# When unset in production, API routes use per-instance memory limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Preview builder (npm install + build on generated projects). RCE risk if enabled.
# H08 / D-004: keep false. Unset or false = off. Production hard-disables even if true.
# Only consider true in local/dev after an Accepted security decision (F01).
WEBSITE_PREVIEW_BUILDER_ENABLED=false

# Public hosted websites at /w/[slug]. Default ON when unset. Set false to disable public hosting.
# In-platform live preview uses /api/website-builder/[id]/live-preview (always available when authenticated).
# WEBSITE_PUBLISH_ENABLED=true
# WEBSITE_PUBLISH_ENABLED=false
