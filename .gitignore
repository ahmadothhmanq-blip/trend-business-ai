# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep template tracked for onboarding
.env*
!.env.example
!.env.staging.example

# local artifacts (never ship)
.tmp/
trend-business-ai.zip
pnpm-lock.yaml
pnpm-workspace.yaml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase cli cache
supabase/.temp/
